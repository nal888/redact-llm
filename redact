 ██████╔╝█████╗  ██║  ██║███████║██║        ██║
 ██╔══██╗██╔══╝  ██║  ██║██╔══██║██║        ██║
 ██║  ██║███████╗██████╔╝██║  ██║╚██████╗   ██║
 ╚═╝  ╚═╝╚══════╝╚═════╝ ╚═╝  ╚═╝ ╚═════╝   ╚═╝
"""


def _print_banner() -> None:
    print(f"{MAG}{_BANNER}{RESET}", end="")
    print(f" {DIM}anonymization proxy for Claude Code{RESET}  "
          f"{DIM}·{RESET}  {DIM}v{__version__}{RESET}")
    print()


def _print_top_help() -> None:
