def cmd_config_show(args) -> None:
    cfg = _load()
    print(f"  {DIM}{CFG_FILE}{RESET}")
    print()
    for k, v in cfg.items():
        display = v if v not in (None, "") else f"{DIM}(unset){RESET}"
        print(f"  {k:<14}  {display}")


def cmd_config_set(args) -> None:
    cfg = _load()
    if args.key not in DEFAULTS:
        print(f"{RED}unknown key: {args.key}{RESET}")
        print(f"valid keys: {', '.join(DEFAULTS.keys())}")
        sys.exit(1)
    v = args.value
    if args.key == "port":
        v = int(v)
    elif args.key == "llm_detector":
        v = v.lower() in ("true", "1", "yes", "on")
    cfg[args.key] = v
    _save(cfg)
    print(f"{GREEN}✓{RESET} set {args.key}={v}")


class _TopHelpParser(argparse.ArgumentParser):
    """Top-level parser that uses our hand-formatted help."""
    def format_help(self) -> str:  # override
        import io
        buf = io.StringIO()
        _stdout = sys.stdout
        sys.stdout = buf
        try:
            _print_top_help()
        finally:
            sys.stdout = _stdout
        return buf.getvalue()


def main() -> None:
    p = _TopHelpParser(
        prog="redact",
        add_help=True,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--version", action="version", version=f"redact {__version__}")
    sub = p.add_subparsers(dest="cmd", metavar="COMMAND", parser_class=argparse.ArgumentParser)

    # start
    sp = sub.add_parser(
        "start",
        help="start proxy in background",
        description="Start the proxy as a background daemon. Defaults are "
                    "read from ~/.redact/config.json; any flag below overrides.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(f"{BOLD}Examples{RESET}\n"
                f"  {CYAN}redact start acme-q2{RESET}\n"
                f"  {CYAN}redact start acme-q2 --port 9000{RESET}\n"
                f"  {CYAN}redact start acme-q2 --no-llm{RESET}         {DIM}# no Ollama needed{RESET}\n"
                f"  {CYAN}redact start acme-q2 --presend block{RESET}  {DIM}# refuse on leak{RESET}"),
    )
    sp.add_argument("engagement", nargs="?",
                    help="engagement name (reuses last if omitted)")
    sp.add_argument("--port", type=int, metavar="N",
                    help="proxy listen port (default: 8181)")
    sp.add_argument("--model", metavar="NAME",
                    help="Ollama model (default: qwen3:4b-instruct-2507-q4_K_M)")
    sp.add_argument("--no-llm", action="store_true",
                    help="disable LLM detection layer (regex-only, no Ollama required)")
    sp.add_argument("--presend", choices=["off", "warn", "block"], metavar="MODE",
                    help="pre-send scanner: off | warn (default) | block")
    sp.add_argument("--upstream", metavar="URL",
                    help="override Anthropic API URL (default: https://api.anthropic.com)")
    sp.add_argument("--ollama-host", metavar="URL",
                    help="Ollama endpoint (default: http://localhost:11434)")
    sp.add_argument("--vault-dir", metavar="DIR",
                    help="vault storage location (default: ~/.anon-proxy)")
    sp.add_argument("--timeout", type=int, metavar="SEC",
                    help="LLM per-call timeout seconds (default: 15)")
    sp.add_argument("-f", "--foreground", action="store_true",
                    help="run in foreground instead of backgrounding (for debugging)")
    sp.add_argument("--wordlist", metavar="FILE",
                    help="path to engagement wordlist (one value per line, "
                         "optional :TYPE suffix). Pass empty string to clear.")
    sp.set_defaults(func=cmd_start)

    # stop
    sp = sub.add_parser("stop", help="stop the running proxy")
    sp.set_defaults(func=cmd_stop)

    # status
    sp = sub.add_parser("status", help="show proxy + config status")
    sp.set_defaults(func=cmd_status)

    # claude
    sp = sub.add_parser(
        "claude",
        help="launch claude with ANTHROPIC_BASE_URL set",
        description="Launch Claude Code through the proxy. Extra args forwarded to claude.",
    )
    sp.add_argument("extras", nargs=argparse.REMAINDER, help="forwarded to claude")
    sp.set_defaults(func=cmd_claude)

    # run
    sp = sub.add_parser(
        "run",
        help="run any command with ANTHROPIC_BASE_URL set",
        description="Run any subprocess through the proxy. Example: redact run -- python script.py",
    )
    sp.add_argument("cmd", nargs=argparse.REMAINDER, metavar="CMD")
    sp.set_defaults(func=cmd_run)

    # tunnel
    sp = sub.add_parser(
        "tunnel",
        help="SSH tunnel from laptop to proxy on VPS",
        description="Open an SSH local-port-forward so your laptop can reach a "
                    "proxy running on a VPS. Blocks until Ctrl+C.",
        epilog=(f"{BOLD}Examples{RESET}\n"
                f"  {CYAN}redact tunnel root@1.2.3.4{RESET}           {DIM}# forward proxy port{RESET}\n"
                f"  {CYAN}redact tunnel root@1.2.3.4 --ollama{RESET}  {DIM}# also forward Ollama (11434){RESET}\n"
                f"  {CYAN}redact tunnel root@1.2.3.4 --port 9000{RESET}"),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sp.add_argument("host", nargs="?", help="SSH destination (user@host)")
    sp.add_argument("--port", type=int, help="proxy port on both sides (default: from config)")
    sp.add_argument("--ollama", action="store_true",
                    help="also forward Ollama port 11434 (for remote LLM)")
    sp.set_defaults(func=cmd_tunnel)

    # logs
    sp = sub.add_parser("logs", help="tail proxy logs")
    sp.add_argument("-f", "--follow", action="store_true", help="follow log (tail -f)")
    sp.add_argument("-n", "--lines", type=int, default=50,
                    help="number of lines to show (default: 50)")
    sp.set_defaults(func=cmd_logs)

    # vault (delegate)
    sp = sub.add_parser(
        "vault",
        help="inspect the vault (list/stats/find/engagements/clear/path)",
        description=(
            f"{BOLD}Vault inspection.{RESET}  "
            "Uses current engagement unless you pass -e NAME.\n\n"
            f"{BOLD}Subcommands{RESET}\n"
            "  list            all real↔fake mappings\n"
            "  stats           counts per entity type\n"
            "  find QUERY      search real or surrogate value\n"
            "  engagements     every engagement you've ever created\n"
            "  clear NAME      delete a vault + secret + audit\n"
            "  path            show file paths for current engagement\n\n"
            f"{BOLD}Examples{RESET}\n"
            f"  {CYAN}redact vault list{RESET}\n"
            f"  {CYAN}redact vault find 10.20.0.10{RESET}\n"
            f"  {CYAN}redact vault clear old-engagement{RESET}"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sp.add_argument("vault_args", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_vault)

    # config
    cfgp = sub.add_parser(
        "config",
        help="view or change persisted defaults",
        description=(
            f"{BOLD}Config.{RESET}  Lives at ~/.redact/config.json.\n\n"
            f"{BOLD}Keys{RESET}\n"
            "  port           proxy listen port (default 8181)\n"
            "  model          Ollama model name\n"
            "  llm_detector   on | off\n"
            "  presend_mode   off | warn | block\n"
            "  engagement     last engagement used\n\n"
            f"{BOLD}Examples{RESET}\n"
            f"  {CYAN}redact config show{RESET}\n"
            f"  {CYAN}redact config set port 9000{RESET}\n"
            f"  {CYAN}redact config set llm_detector off{RESET}"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    cfgsub = cfgp.add_subparsers(dest="subcmd", metavar="SUBCMD")
    csp = cfgsub.add_parser("show", help="print current config")
    csp.set_defaults(func=cmd_config_show)
    csp = cfgsub.add_parser("set", help="update a config value")
    csp.add_argument("key", help="port | model | llm_detector | presend_mode | engagement")
    csp.add_argument("value")
    csp.set_defaults(func=cmd_config_set)
    cfgp.set_defaults(func=lambda _a: cfgp.print_help())

    args = p.parse_args()
