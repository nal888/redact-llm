    print(f"  {CYAN}redact stop{RESET}                   {DIM}# stop when done{RESET}")
    print()
    print(f"  Run {CYAN}redact <command> -h{RESET} for details on each command.")
    print()


def _load() -> dict:
    if CFG_FILE.exists():
        try:
            return {**DEFAULTS, **json.loads(CFG_FILE.read_text())}
        except json.JSONDecodeError:
            pass
    return dict(DEFAULTS)


def _save(cfg: dict) -> None:
    CFG_FILE.write_text(json.dumps(cfg, indent=2))


def _running_pid() -> int | None:
    if not PID_FILE.exists():
        return None
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return pid
    except (OSError, ValueError):
        PID_FILE.unlink(missing_ok=True)
        return None


def _ollama_ok() -> bool:
    try:
        import urllib.request
        urllib.request.urlopen(
            os.environ.get("OLLAMA_HOST", "http://localhost:11434") + "/api/tags",
            timeout=1,
        )
        return True
    except Exception:
        return False


def _check_venv() -> None:
    if not UVICORN.exists():
        print(f"{RED}venv missing — run: ./scripts/install.sh{RESET}", file=sys.stderr)
        sys.exit(1)


# ---------- commands ----------

def cmd_start(args) -> None:
    _check_venv()
    cfg = _load()
    engagement = args.engagement or cfg.get("engagement")
    if not engagement:
        print(f"{RED}error:{RESET} engagement name is required")
        print(f"   {CYAN}redact start <client-name>{RESET}")
        print(f"   {DIM}example: redact start acme-corp-2026-q2{RESET}")
        sys.exit(1)
    cfg["engagement"] = engagement
    if args.port:
        cfg["port"] = args.port
    if args.model:
        cfg["model"] = args.model
    if args.no_llm:
        cfg["llm_detector"] = False
    if args.presend:
        cfg["presend_mode"] = args.presend
    if args.wordlist is not None:
        cfg["wordlist"] = args.wordlist or None
    _save(cfg)

    pid = _running_pid()
    if pid:
        print(f"{YELLOW}proxy already running (pid {pid}).{RESET} stop first: redact stop")
        return

    ollama_host = args.ollama_host or os.environ.get("OLLAMA_HOST", "http://localhost:11434")
    llm_reachable = _ollama_ok() if not args.ollama_host else True  # trust user's override
    llm_on = cfg["llm_detector"] and llm_reachable
    if cfg["llm_detector"] and not llm_reachable:
        print(f"{YELLOW}⚠  Ollama not reachable at {ollama_host} — starting in regex-only mode.{RESET}")
        print(f"   install: curl -fsSL https://ollama.com/install.sh | sh")
        print(f"   then: ollama pull {cfg['model']}")

    env = os.environ.copy()
    env.update({
        "ENGAGEMENT_ID": engagement,
        "PORT": str(cfg["port"]),
        "LLM_DETECTOR": "true" if llm_on else "false",
        "LLM_MODEL": cfg["model"],
        "PRESEND_MODE": cfg["presend_mode"],
        "OLLAMA_HOST": ollama_host,
    })
    if args.upstream:
        env["UPSTREAM_URL"] = args.upstream
    if args.vault_dir:
        env["VAULT_DIR"] = args.vault_dir
    if args.timeout:
        env["LLM_TIMEOUT"] = str(args.timeout)
    wordlist = cfg.get("wordlist")
    if wordlist:
        env["WORDLIST_PATH"] = wordlist

    cmd = [str(UVICORN), "anon_proxy.server:app",
           "--app-dir", str(HERE),
           "--host", "127.0.0.1",
           "--port", str(cfg["port"]),
           "--log-level", "info"]

    if args.foreground:
        print(f"{DIM}running in foreground — Ctrl+C to stop{RESET}")
        for k, v in sorted(env.items()):
            if k.startswith(("ENGAGEMENT_", "LLM_", "PRESEND_", "OLLAMA_", "UPSTREAM_", "VAULT_", "PORT")):
                print(f"  {k}={v}")
        os.execvpe(cmd[0], cmd, env)
        return

    log_f = open(LOG_FILE, "a")
    log_f.write(f"\n===== proxy starting at {time.strftime('%Y-%m-%d %H:%M:%S')} =====\n")
    log_f.flush()
    proc = subprocess.Popen(
        cmd, cwd=HERE, env=env, stdout=log_f, stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    PID_FILE.write_text(str(proc.pid))
    time.sleep(1.5)
    if proc.poll() is not None:
        print(f"{RED}✗ proxy died immediately — see {LOG_FILE}{RESET}")
        PID_FILE.unlink(missing_ok=True)
        sys.exit(1)

    print(f"  {GREEN}●{RESET} proxy started   {DIM}pid {proc.pid}   http://localhost:{cfg['port']}{RESET}")
    print()
    rows = [
        ("engagement", f"{CYAN}{engagement}{RESET}"),
        ("llm",        cfg['model'] if llm_on else f"{DIM}off{RESET}"),
        ("presend",    cfg['presend_mode']),
    ]
    if args.upstream:
        rows.append(("upstream", args.upstream))
    if args.ollama_host and args.ollama_host != "http://localhost:11434":
        rows.append(("ollama", args.ollama_host))
    if args.vault_dir:
        rows.append(("vault dir", args.vault_dir))
    rows.append(("logs", str(LOG_FILE)))
    for k, v in rows:
        print(f"  {k:<12}  {v}")
    print()
    print(f"  next:  {CYAN}redact claude{RESET}")


def cmd_stop(args) -> None:
    pid = _running_pid()
    if not pid:
        print(f"{DIM}proxy not running{RESET}")
        return
    try:
        os.kill(pid, signal.SIGTERM)
        for _ in range(10):
            time.sleep(0.2)
            if _running_pid() is None:
                break
        else:
            os.kill(pid, signal.SIGKILL)
    except OSError:
        pass
    PID_FILE.unlink(missing_ok=True)
    print(f"{GREEN}✓ proxy stopped{RESET} (pid {pid})")


def cmd_status(args) -> None:
    pid = _running_pid()
    cfg = _load()
    engagement = cfg.get("engagement") or ""

    if pid:
        print(f"  {GREEN}●{RESET} proxy running   {DIM}pid {pid}   http://localhost:{cfg['port']}{RESET}")
    else:
        print(f"  {DIM}○ proxy stopped{RESET}")
    print()
    rows = [
        ("engagement",  engagement or f"{DIM}(none){RESET}"),
        ("llm",         f"{cfg['model']}" if cfg['llm_detector'] else f"{DIM}off{RESET}"),
        ("ollama",      "reachable" if _ollama_ok() else f"{DIM}not reachable{RESET}"),
        ("presend",     cfg.get("presend_mode", "warn")),
        ("config",      str(CFG_FILE)),
    ]
    for k, v in rows:
        print(f"  {k:<12}  {v}")


def cmd_claude(args) -> None:
    pid = _running_pid()
    cfg = _load()
    if not pid:
        print(f"{RED}proxy not running.{RESET} start it first: redact start <engagement>")
        sys.exit(1)
    env = os.environ.copy()
    env["ANTHROPIC_BASE_URL"] = f"http://localhost:{cfg['port']}"
    try:
        os.execvpe("claude", ["claude", *args.extras], env)
    except FileNotFoundError:
        print(f"{RED}claude CLI not found in PATH{RESET}")
        sys.exit(1)


def cmd_run(args) -> None:
    # Strip leading '--' separator if present (argparse keeps it with REMAINDER)
    cmd = list(args.cmd)
    while cmd and cmd[0] == "--":
        cmd.pop(0)
    if not cmd:
        print(f"{RED}error:{RESET} no command given")
        print(f"  {CYAN}redact run -- <command> [args...]{RESET}")
        print(f"  {DIM}example: redact run -- python my_script.py{RESET}")
        sys.exit(1)
    pid = _running_pid()
    cfg = _load()
    if not pid:
        print(f"{RED}error:{RESET} proxy not running")
        print(f"  start it first: {CYAN}redact start <engagement>{RESET}")
        sys.exit(1)
    env = os.environ.copy()
    env["ANTHROPIC_BASE_URL"] = f"http://localhost:{cfg['port']}"
    try:
        os.execvpe(cmd[0], cmd, env)
    except FileNotFoundError:
        print(f"{RED}error:{RESET} command not found: {cmd[0]}")
        sys.exit(127)


def cmd_tunnel(args) -> None:
    """Open an SSH tunnel: laptop:PORT  ↔  vps:PORT (local port-forward)."""
    if not args.host:
        print(f"{RED}error:{RESET} need an SSH destination")
        print(f"  {CYAN}redact tunnel user@vps-ip{RESET}")
        sys.exit(1)
    cfg = _load()
    port = args.port or cfg.get("port", 8181)
    ollama_port = 11434 if args.ollama else None

    # Build ssh command
    ssh_cmd = ["ssh", "-N", "-L", f"{port}:localhost:{port}"]
    if ollama_port:
        ssh_cmd += ["-L", f"{ollama_port}:localhost:{ollama_port}"]
    ssh_cmd += [args.host]

    print(f"  {GREEN}●{RESET} opening tunnel   {DIM}{args.host}{RESET}")
    print()
    print(f"  laptop localhost:{port}  {DIM}↔{RESET}  vps localhost:{port}  {DIM}(proxy){RESET}")
    if ollama_port:
        print(f"  laptop localhost:{ollama_port}  {DIM}↔{RESET}  vps localhost:{ollama_port}  {DIM}(ollama){RESET}")
    print()
    print(f"  next (in another laptop terminal):")
    print(f"    {CYAN}export ANTHROPIC_BASE_URL=http://localhost:{port}{RESET}")
    print(f"    {CYAN}claude{RESET}")
    print()
    print(f"  {DIM}Ctrl+C here closes the tunnel.{RESET}")
    print()
    try:
        os.execvp("ssh", ssh_cmd)
    except FileNotFoundError:
        print(f"{RED}error:{RESET} ssh not found in PATH")
        sys.exit(1)


def cmd_logs(args) -> None:
    if not LOG_FILE.exists():
        print(f"{DIM}no logs yet{RESET}")
        return
    cmd = ["tail", "-f", str(LOG_FILE)] if args.follow else ["tail", "-n", str(args.lines), str(LOG_FILE)]
    subprocess.run(cmd)


def cmd_vault(args) -> None:
    # Show our own help if no subcommand given, instead of forwarding to
    # the vault script (which errors out).
    if not args.vault_args:
        _print_vault_help()
        return
    cfg = _load()
    if cfg.get("engagement") and "-e" not in args.vault_args and "--engagement" not in args.vault_args:
        if args.vault_args[0] in ("list", "stats", "find", "path"):
            args.vault_args = [args.vault_args[0], "-e", cfg["engagement"], *args.vault_args[1:]]
    os.execvp(str(VAULT_SCRIPT), ["vault", *args.vault_args])


