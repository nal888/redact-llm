#!/usr/bin/env python3
# redact — local anonymization proxy for Claude Code.
__version__ = "1.0.0"
import argparse
import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent   # follow symlinks so global installs work
VENV = HERE / ".venv"
UVICORN = VENV / "bin" / "uvicorn"
VAULT_SCRIPT = HERE / "scripts" / "vault"

STATE_DIR = Path(os.environ.get("REDACT_STATE_DIR", Path.home() / ".redact"))
STATE_DIR.mkdir(parents=True, exist_ok=True)
CFG_FILE = STATE_DIR / "config.json"
PID_FILE = STATE_DIR / "proxy.pid"
LOG_FILE = STATE_DIR / "proxy.log"

DEFAULTS = {
    "port": 8181,
    "model": "qwen3:4b-instruct-2507-q4_K_M",
    "llm_detector": True,
    "presend_mode": "warn",
    "engagement": None,
}

# ANSI — disable if not a TTY or NO_COLOR set
_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None
